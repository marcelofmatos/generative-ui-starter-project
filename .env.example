# generative-ui-starter-project — runtime environment variables.
# Copie para .env: cp .env.example .env

# --- Agente (backend LangGraph/AG-UI) — detém a chave de API ---
# OpenAI API key (https://platform.openai.com/api-keys)  [OBRIGATÓRIA]
OPENAI_API_KEY=

# --- URL front→agente (o default funciona na imagem combinada) ---
AGENT_URL=http://localhost:8123
